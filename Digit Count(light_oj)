 #include <bits/stdc++.h>
using namespace std;
   long long sol(int ind, int last, int m,  map<int, int> &digitcontains, vector<vector<int>> &dp){      
           if(ind>=m){
               return 1;
           }
               if(dp[ind][last+1]!=-1){
                    return dp[ind][last+1];
               }
                int ans=0;
             for(int i=1; i<=9; i++){
                  if(digitcontains[i]>0 && (last==-1 || abs(last-i)<=2)){
                  ans+=sol(ind+1, i, m, digitcontains, dp);
                  }
             }
             return dp[ind][last+1]=ans;
     }
int main() 
{
       int t; cin>>t;
        int tp=1;
         while(tp<=t){
                int n, m;
                cin>>n>>m;
                map<int, int> digitcontains;
                  for(int i=0; i<n; i++){
                      int v; cin>>v;
                        digitcontains[v]++;
                  }
                  vector<vector<int>> dp(11, vector<int>(12, -1));
                  long long v2=sol(0, -1, m, digitcontains, dp);
                 cout<<"Case"<<" "<<tp<<": "<<v2<<endl;
             tp++;
           
         }
}
