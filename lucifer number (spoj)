  long long sol(int ind,string &l, bool flg, int cnt1,int cnt2,vector<vector<vector<vector<int>>>> &dp){      
           if(ind>=l.size()){
                 if(prime.find((cnt1-cnt2))!=prime.end()){
                   return 1;
                 }
               return 0;
           }
             if(dp[ind][flg][cnt1][cnt2]!=-1){
                  return dp[ind][flg][cnt1][cnt2];
             }
           int limit=(flg==true)?l[ind]-'0':9; int ans=0;
             for(int i=0; i<=limit; i++){
                  int pos=(l.size()-ind);
                  if(pos%2==0){
                  int updatecnt=cnt1+i;
                  ans+=sol(ind+1, l, (flg & (i==(l[ind]-'0'))), updatecnt,cnt2, dp);
                  }else{
                     int updatecnt=cnt2+i;
                  ans+=sol(ind+1, l, (flg & (i==(l[ind]-'0'))),cnt1, updatecnt, dp);
                  }
             }
             return dp[ind][flg][cnt1][cnt2]=ans;
     }
